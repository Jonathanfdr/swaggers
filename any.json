swagger: '2.0'

info:
  title: API de Gestão Comercial
  version: '1.0.0'
  description: API exemplo com Usuários, Clientes, Produtos e Vendas.

host: api.exemplo.com
basePath: /v1

schemes:
  - https

consumes:
  - application/json

produces:
  - application/json

tags:
  - name: Usuários
  - name: Clientes
  - name: Produtos
  - name: Vendas

paths:

  /usuarios:
    get:
      tags:
        - Usuários
      summary: Listar usuários
      parameters:
        - name: pagina
          in: query
          type: integer

        - name: limite
          in: query
          type: integer

        - name: x-canal-origem
          in: header
          type: string
          enum:
            - WEB
            - MOBILE
            - API

      responses:
        200:
          description: Lista de usuários

    post:
      tags:
        - Usuários
      summary: Criar usuário

      parameters:
        - name: x-correlation-id
          in: header
          type: string

        - name: body
          in: body
          required: true
          schema:
            $ref: '#/definitions/UsuarioCreate'

      responses:
        201:
          description: Usuário criado

  /usuarios/{id}:
    get:
      tags:
        - Usuários
      summary: Buscar usuário

      parameters:
        - name: id
          in: path
          required: true
          type: integer

      responses:
        200:
          description: Usuário encontrado

    put:
      tags:
        - Usuários
      summary: Atualizar usuário

      parameters:
        - name: id
          in: path
          required: true
          type: integer

        - name: body
          in: body
          required: true
          schema:
            $ref: '#/definitions/UsuarioUpdate'

      responses:
        200:
          description: Usuário atualizado

    patch:
      tags:
        - Usuários
      summary: Atualizar parcialmente usuário

      parameters:
        - name: id
          in: path
          required: true
          type: integer

        - name: body
          in: body
          schema:
            type: object
            properties:
              nome:
                type: string

              email:
                type: string

      responses:
        200:
          description: Usuário atualizado

    delete:
      tags:
        - Usuários
      summary: Excluir usuário

      parameters:
        - name: id
          in: path
          required: true
          type: integer

      responses:
        204:
          description: Usuário removido

  /clientes:
    get:
      tags:
        - Clientes
      summary: Listar clientes

      parameters:
        - name: cidade
          in: query
          type: string

        - name: ativo
          in: query
          type: boolean

      responses:
        200:
          description: Lista de clientes

    post:
      tags:
        - Clientes
      summary: Criar cliente

      parameters:
        - name: body
          in: body
          required: true
          schema:
            $ref: '#/definitions/Cliente'

      responses:
        201:
          description: Cliente criado

  /clientes/{clienteId}:
    get:
      tags:
        - Clientes
      summary: Buscar cliente

      parameters:
        - name: clienteId
          in: path
          required: true
          type: integer

      responses:
        200:
          description: Cliente encontrado

    put:
      tags:
        - Clientes
      summary: Atualizar cliente

      parameters:
        - name: clienteId
          in: path
          required: true
          type: integer

        - name: body
          in: body
          required: true
          schema:
            $ref: '#/definitions/Cliente'

      responses:
        200:
          description: Cliente atualizado

    delete:
      tags:
        - Clientes
      summary: Excluir cliente

      parameters:
        - name: clienteId
          in: path
          required: true
          type: integer

      responses:
        204:
          description: Cliente removido

  /produtos:
    get:
      tags:
        - Produtos
      summary: Listar produtos

      parameters:
        - name: categoria
          in: query
          type: string

        - name: precoMin
          in: query
          type: number

        - name: precoMax
          in: query
          type: number

      responses:
        200:
          description: Lista de produtos

    post:
      tags:
        - Produtos
      summary: Criar produto

      parameters:
        - name: x-loja-id
          in: header
          type: string

        - name: body
          in: body
          required: true
          schema:
            $ref: '#/definitions/Produto'

      responses:
        201:
          description: Produto criado

  /produtos/{produtoId}:
    get:
      tags:
        - Produtos
      summary: Buscar produto

      parameters:
        - name: produtoId
          in: path
          required: true
          type: integer

      responses:
        200:
          description: Produto encontrado

    put:
      tags:
        - Produtos
      summary: Atualizar produto

      parameters:
        - name: produtoId
          in: path
          required: true
          type: integer

        - name: body
          in: body
          required: true
          schema:
            $ref: '#/definitions/Produto'

      responses:
        200:
          description: Produto atualizado

    patch:
      tags:
        - Produtos
      summary: Atualizar estoque

      parameters:
        - name: produtoId
          in: path
          required: true
          type: integer

        - name: body
          in: body
          schema:
            type: object
            properties:
              estoque:
                type: integer

      responses:
        200:
          description: Estoque atualizado

    delete:
      tags:
        - Produtos
      summary: Excluir produto

      parameters:
        - name: produtoId
          in: path
          required: true
          type: integer

      responses:
        204:
          description: Produto removido

  /vendas:
    get:
      tags:
        - Vendas
      summary: Listar vendas

      parameters:
        - name: dataInicio
          in: query
          type: string
          format: date

        - name: dataFim
          in: query
          type: string
          format: date

      responses:
        200:
          description: Lista de vendas

    post:
      tags:
        - Vendas
      summary: Registrar venda

      parameters:
        - name: x-request-id
          in: header
          type: string

        - name: body
          in: body
          required: true
          schema:
            $ref: '#/definitions/Venda'

      responses:
        201:
          description: Venda criada

  /vendas/{vendaId}:
    get:
      tags:
        - Vendas
      summary: Buscar venda

      parameters:
        - name: vendaId
          in: path
          required: true
          type: integer

      responses:
        200:
          description: Venda encontrada

    patch:
      tags:
        - Vendas
      summary: Alterar status da venda

      parameters:
        - name: vendaId
          in: path
          required: true
          type: integer

        - name: body
          in: body
          schema:
            type: object
            properties:
              status:
                type: string

      responses:
        200:
          description: Status atualizado

    delete:
      tags:
        - Vendas
      summary: Cancelar venda

      parameters:
        - name: vendaId
          in: path
          required: true
          type: integer

      responses:
        204:
          description: Venda cancelada

definitions:

  UsuarioCreate:
    type: object
    required:
      - nome
      - email
      - senha
    properties:
      nome:
        type: string

      email:
        type: string

      senha:
        type: string

  UsuarioUpdate:
    type: object
    properties:
      nome:
        type: string

      email:
        type: string

  Cliente:
    type: object
    properties:
      nome:
        type: string

      cpf:
        type: string

      telefone:
        type: string

      cidade:
        type: string

  Produto:
    type: object
    properties:
      nome:
        type: string

      descricao:
        type: string

      preco:
        type: number

      estoque:
        type: integer

  Venda:
    type: object
    properties:
      clienteId:
        type: integer

      produtos:
        type: array
        items:
          type: object
          properties:
            produtoId:
              type: integer

            quantidade:
              type: integer

      valorTotal:
        type: number
