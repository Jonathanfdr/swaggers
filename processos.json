openapi: 3.0.3

info:
  title: API de Gestão Comercial
  version: 1.0.0
  description: API exemplo com Usuários, Clientes, Produtos e Vendas.

servers:
  - url: https://api.exemplo.com/v1

tags:
  - name: Usuários
  - name: Clientes
  - name: Produtos
  - name: Vendas

paths:

  #################################################
  # USUÁRIOS
  #################################################

  /usuarios:
    get:
      tags:
        - Usuários
      summary: Listar usuários
      parameters:
        - name: pagina
          in: query
          description: Número da página
          schema:
            type: integer
            example: 1

        - name: limite
          in: query
          description: Quantidade de registros por página
          schema:
            type: integer
            example: 10

        - name: x-canal-origem
          in: header
          description: Canal que realizou a requisição
          schema:
            type: string
            enum:
              - WEB
              - MOBILE
              - API

      responses:
        '200':
          description: Lista de usuários

    post:
      tags:
        - Usuários
      summary: Criar usuário

      parameters:
        - name: x-correlation-id
          in: header
          description: Identificador da requisição
          schema:
            type: string

      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UsuarioCreate'

      responses:
        '201':
          description: Usuário criado

  /usuarios/{id}:
    get:
      tags:
        - Usuários
      summary: Buscar usuário por ID

      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer

      responses:
        '200':
          description: Usuário encontrado

    put:
      tags:
        - Usuários
      summary: Atualizar usuário completamente

      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer

      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UsuarioUpdate'

      responses:
        '200':
          description: Usuário atualizado

    patch:
      tags:
        - Usuários
      summary: Atualizar parcialmente um usuário

      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer

      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                nome:
                  type: string
                email:
                  type: string
                  format: email

      responses:
        '200':
          description: Usuário atualizado parcialmente

    delete:
      tags:
        - Usuários
      summary: Remover usuário

      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer

      responses:
        '204':
          description: Usuário removido

  #################################################
  # CLIENTES
  #################################################

  /clientes:
    get:
      tags:
        - Clientes
      summary: Listar clientes

      parameters:
        - name: cidade
          in: query
          schema:
            type: string

        - name: ativo
          in: query
          schema:
            type: boolean

      responses:
        '200':
          description: Lista de clientes

    post:
      tags:
        - Clientes
      summary: Criar cliente

      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Cliente'

      responses:
        '201':
          description: Cliente criado

  /clientes/{clienteId}:
    get:
      tags:
        - Clientes
      summary: Buscar cliente por ID

      parameters:
        - name: clienteId
          in: path
          required: true
          schema:
            type: integer

      responses:
        '200':
          description: Cliente encontrado

    put:
      tags:
        - Clientes
      summary: Atualizar cliente

      parameters:
        - name: clienteId
          in: path
          required: true
          schema:
            type: integer

      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Cliente'

      responses:
        '200':
          description: Cliente atualizado

    delete:
      tags:
        - Clientes
      summary: Excluir cliente

      parameters:
        - name: clienteId
          in: path
          required: true
          schema:
            type: integer

      responses:
        '204':
          description: Cliente removido

  #################################################
  # PRODUTOS
  #################################################

  /produtos:
    get:
      tags:
        - Produtos
      summary: Listar produtos

      parameters:
        - name: categoria
          in: query
          schema:
            type: string

        - name: precoMin
          in: query
          schema:
            type: number
            format: double

        - name: precoMax
          in: query
          schema:
            type: number
            format: double

      responses:
        '200':
          description: Lista de produtos

    post:
      tags:
        - Produtos
      summary: Criar produto

      parameters:
        - name: x-loja-id
          in: header
          description: Identificador da loja
          schema:
            type: string

      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Produto'

      responses:
        '201':
          description: Produto criado

  /produtos/{produtoId}:
    get:
      tags:
        - Produtos
      summary: Buscar produto

      parameters:
        - name: produtoId
          in: path
          required: true
          schema:
            type: integer

      responses:
        '200':
          description: Produto encontrado

    put:
      tags:
        - Produtos
      summary: Atualizar produto completamente

      parameters:
        - name: produtoId
          in: path
          required: true
          schema:
            type: integer

      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Produto'

      responses:
        '200':
          description: Produto atualizado

    patch:
      tags:
        - Produtos
      summary: Atualizar estoque do produto

      parameters:
        - name: produtoId
          in: path
          required: true
          schema:
            type: integer

      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                estoque:
                  type: integer
                  example: 150

      responses:
        '200':
          description: Estoque atualizado

    delete:
      tags:
        - Produtos
      summary: Excluir produto

      parameters:
        - name: produtoId
          in: path
          required: true
          schema:
            type: integer

      responses:
        '204':
          description: Produto removido

  #################################################
  # VENDAS
  #################################################

  /vendas:
    get:
      tags:
        - Vendas
      summary: Listar vendas

      parameters:
        - name: dataInicio
          in: query
          schema:
            type: string
            format: date

        - name: dataFim
          in: query
          schema:
            type: string
            format: date

        - name: status
          in: query
          schema:
            type: string
            enum:
              - PENDENTE
              - CONCLUIDA
              - CANCELADA

      responses:
        '200':
          description: Lista de vendas

    post:
      tags:
        - Vendas
      summary: Registrar venda

      parameters:
        - name: x-request-id
          in: header
          description: Identificador único da requisição
          schema:
            type: string

      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Venda'

      responses:
        '201':
          description: Venda registrada

  /vendas/{vendaId}:
    get:
      tags:
        - Vendas
      summary: Buscar venda por ID

      parameters:
        - name: vendaId
          in: path
          required: true
          schema:
            type: integer

      responses:
        '200':
          description: Venda encontrada

    patch:
      tags:
        - Vendas
      summary: Alterar status da venda

      parameters:
        - name: vendaId
          in: path
          required: true
          schema:
            type: integer

      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                status:
                  type: string
                  enum:
                    - PENDENTE
                    - CONCLUIDA
                    - CANCELADA

      responses:
        '200':
          description: Status atualizado

    delete:
      tags:
        - Vendas
      summary: Cancelar venda

      parameters:
        - name: vendaId
          in: path
          required: true
          schema:
            type: integer

      responses:
        '204':
          description: Venda cancelada

components:
  schemas:

    UsuarioCreate:
      type: object
      required:
        - nome
        - email
        - senha

      properties:
        nome:
          type: string
          example: João Silva

        email:
          type: string
          format: email
          example: joao@email.com

        senha:
          type: string
          example: Senha@123

    UsuarioUpdate:
      type: object

      properties:
        nome:
          type: string

        email:
          type: string
          format: email

    Cliente:
      type: object

      required:
        - nome
        - cpf

      properties:
        nome:
          type: string
          example: Maria Souza

        cpf:
          type: string
          example: 12345678900

        telefone:
          type: string
          example: 41999999999

        cidade:
          type: string
          example: Curitiba

    Produto:
      type: object

      required:
        - nome
        - preco

      properties:
        nome:
          type: string
          example: Notebook Dell

        descricao:
          type: string
          example: Notebook para uso corporativo

        preco:
          type: number
          format: double
          example: 4599.90

        estoque:
          type: integer
          example: 25

    Venda:
      type: object

      required:
        - clienteId
        - produtos

      properties:
        clienteId:
          type: integer
          example: 1

        produtos:
          type: array
          items:
            type: object
            properties:
              produtoId:
                type: integer
                example: 10

              quantidade:
                type: integer
                example: 2

        valorTotal:
          type: number
          format: double
          example: 9199.80
